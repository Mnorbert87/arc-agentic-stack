# Copy to .env and fill in. Never commit real keys — .env is gitignored.

# Buyer agent key (the payer). Use a dedicated burner, never a real-money key.
AGENT_PRIVATE_KEY=0x...

# Server key (the payee that receives + withdraws the stream). Dedicated burner.
SERVER_PRIVATE_KEY=0x...

# Arc Testnet (defaults baked into the code; override only if needed)
RPC_URL=https://rpc.testnet.arc.network
USDC=0x3600000000000000000000000000000000000000
STREAM_PAY=0x505739d33D85AD85D0f9eeE64856309782382450

SERVER_URL=http://localhost:4021
PORT=4021
DEPOSIT_USDC=0.30
STREAM_SECS=60
CALLS=3
